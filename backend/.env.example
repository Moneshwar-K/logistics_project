# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=/api
CORS_ORIGIN=http://localhost:3000

# MongoDB Atlas Connection
# Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/logistics_erp?retryWrites=true&w=majority

# JWT Authentication
# IMPORTANT: Use a strong, unique secret in production!
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info

# AWS S3 (Optional - for production file storage)
# Leave empty to use local file storage
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Email Configuration (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@logistics-erp.com

# SMS Configuration (Optional - for notifications)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
